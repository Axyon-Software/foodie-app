# ===========================================
# STRIPE - Cartões de Crédito/Débito
# ===========================================
# Obtenha as chaves em https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key

# ===========================================
# MERCADO PAGO - Cartões, Pix, Boleto
# ===========================================
# Obtenha as chaves em https://dashboard.mercadopago.com.br/aplications
MERCADOPAGO_ACCESS_TOKEN=your_access_token
MERCADOPAGO_PUBLIC_KEY=your_public_key

# ===========================================
# PAYPAL - PayPal
# ===========================================
# Obtenha as chaves em https://developer.paypal.com
PAYPAL_CLIENT_ID=your_client_id
PAYPAL_CLIENT_SECRET=your_client_secret
PAYPAL_MODE=sandbox  # sandbox ou live

# ===========================================
# PAGSEGURO - Cartões, Pix, Boleto
# ===========================================
# Obtenha as chaves em https://pagseguro.uol.com.br
PAGSEGURO_EMAIL=your_email
PAGSEGURO_TOKEN=your_token
PAGSEGURO_MODE=sandbox

# ===========================================
# PIX - Configurações
# ===========================================
PIX_KEY=seu@email.com
PIX_KEY_TYPE=email  # email, cpf, cnpj, telefone, aleatoria

# ===========================================
# APP URL
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
